---
import { getCollection, getEntryBySlug } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import PostHero from '../../components/Blog/PostHero.astro';
import TableOfContents from '../../components/Blog/TableOfContents.astro';
import { estimateReadingTimeMinutes } from '../../utils/blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = await getEntryBySlug('blog', slug);

if (!post) {
  throw new Error('Blog post not found');
}

const { Content, headings } = await post.render();
const readingTimeMinutes = estimateReadingTimeMinutes(post.body);
---

<BlogLayout title={`${post.data.title} - Kundan Gosavi`} description={post.data.title}>
  <section class="blog-page bg-zinc-50 text-zinc-800 dark:bg-black dark:text-zinc-200">

    <PostHero
      title={post.data.title}
      category={post.data.category}
      publishedDate={post.data.date}
      readingTimeMinutes={readingTimeMinutes}
    />

    <section class="relative z-10 mx-auto grid w-full max-w-6xl grid-cols-1 gap-8 pb-20 md:px-10 xl:grid-cols-[minmax(0,1fr)_300px] xl:items-start">
      <article class="post-body bg-zinc-50 py-8 dark:border-transparent dark:bg-black dark:shadow-none md:px-10 md:py-10" style="padding-left: 0px;">
        <Content />
      </article>

      <div class="xl:block">
        <div class="sticky top-28">
          <TableOfContents headings={headings} />
        </div>
      </div>
    </section>
  </section>
</BlogLayout>

<style>
  .blog-page {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
  }

  .post-body :global(h2),
  .post-body :global(h3) {
    scroll-margin-top: 7.5rem;
  }

  .post-body :global(h2) {
    margin-top: 2.4rem;
    margin-bottom: 1rem;
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.7rem, 1.45rem + 0.8vw, 2.15rem);
    color: rgb(17 24 39);
  }

  .post-body :global(h3) {
    margin-top: 1.7rem;
    margin-bottom: 0.75rem;
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.25rem, 1.1rem + 0.5vw, 1.6rem);
    color: rgb(31 41 55);
  }

  .post-body :global(p),
  .post-body :global(li) {
    line-height: 1.9;
    font-size: clamp(0.95rem, 0.92rem + 0.16vw, 1.06rem);
    color: rgb(63 63 70);
    font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;
  }

  .post-body :global(a) {
    color: rgb(2 132 199);
    text-decoration: underline;
    text-decoration-color: rgb(2 132 199 / 0.45);
    text-underline-offset: 3px;
  }

  .post-body :global(a:hover) {
    color: rgb(3 105 161);
  }

  .post-body :global(pre) {
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    border-radius: 0.9rem;
    border: 1px solid rgb(228 228 231);
    background: rgb(250 250 250);
    padding: 1rem;
    overflow-x: auto;
  }

  .post-body :global(blockquote) {
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    border-left: 3px solid rgb(2 132 199);
    padding-left: 1rem;
    color: rgb(63 63 70);
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin-top: 1rem;
    margin-bottom: 1.5rem;
    padding-left: 1.3rem;
  }

  :global(html.dark) .post-body :global(h2) {
    color: rgb(244 244 245);
  }

  :global(html.dark) .post-body :global(h3) {
    color: rgb(228 228 231);
  }

  :global(html.dark) .post-body :global(p),
  :global(html.dark) .post-body :global(li) {
    color: rgb(212 212 216);
  }

  :global(html.dark) .post-body :global(a) {
    color: rgb(125 211 252);
    text-decoration-color: rgb(14 116 144 / 0.55);
  }

  :global(html.dark) .post-body :global(a:hover) {
    color: rgb(186 230 253);
  }

  :global(html.dark) .post-body :global(pre) {
    border: 1px solid rgb(39 39 42);
    background: rgb(9 9 11);
  }

  :global(html.dark) .post-body :global(blockquote) {
    border-left-color: rgb(14 116 144);
    color: rgb(212 212 216);
  }
</style>