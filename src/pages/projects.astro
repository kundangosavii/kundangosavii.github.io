---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import ProjectCard from '../components/Project/Projectcard.astro';
import { ArrowDown } from 'lucide-react';

const projects = await getCollection('projects');

---

<MainLayout title="Projects - Kundan Gosavi">
  <div id="main-content" class="min-h-screen bg-white dark:bg-black">
    <div class="mx-auto max-w-6xl px-6 pt-10 pb-8 md:px-10 md:pt-14 md:pb-10">
      <h1 class="mb-4 font-playfair text-5xl text-zinc-900 dark:text-white">My Projects</h1>
      <p class="text-gray-600 dark:text-white/50 text-base">
        Here are some of the projects I've been working on.
      </p>
    </div>

    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-4 px-4 pb-20 sm:px-6 md:grid-cols-2 md:gap-6 md:px-10">
      {projects.map((proj) => (
        <ProjectCard
          thumbnail={proj.data.thumbnail}
          altText={proj.data.altText}
          title={proj.data.title}
          hook={proj.data.hook}
          tags={proj.data.tags}
          category={proj.data.category}
          date={proj.data.date}
          projectUrl={proj.data.projectUrl}
          githubUrl={proj.data.githubUrl}
          link={`/projects/${proj.slug}`}
        />
      ))}
    </div>
  </div>
</MainLayout>
