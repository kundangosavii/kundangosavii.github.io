    <div class="flex w-full max-w-md flex-col items-stretch gap-3 px-4 sm:flex-row sm:items-center sm:gap-2 sm:px-0">
        <input
            type="text"
            placeholder="connect@email.com"
            class="w-full rounded border border-gray-300 bg-white px-4 py-3 font-mono text-gray-900 transition focus:border-yellow-500 focus:outline-none dark:border-gray-900 dark:bg-black dark:text-gray-100 sm:py-2"
        />
        <button
            type="button"
            class="rounded bg-gray-200 px-5 py-3 font-mono text-xs text-gray-900 transition-colors duration-200 hover:bg-gray-800 hover:text-white dark:bg-gray-900 dark:text-gray-200 sm:py-3"
        >
            Subscribe
