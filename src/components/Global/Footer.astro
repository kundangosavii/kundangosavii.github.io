<footer class="mt-16 w-full bg-white py-12 text-center dark:bg-black">
    <div class="mx-auto flex w-full max-w-none flex-col items-center gap-6 px-4 text-center sm:max-w-md sm:px-6">
        <span class="text-xs uppercase tracking-widest text-gray-600">Stay connected</span>

        <div class="flex w-full flex-col items-stretch gap-3 sm:flex-row sm:items-center sm:justify-center sm:gap-2">
            <input
                type="text"
                placeholder="connect@email.com"
                class="w-full rounded border border-gray-300 bg-white px-4 py-3 font-mono text-gray-900 transition focus:border-yellow-500 focus:outline-none dark:border-gray-900 dark:bg-black dark:text-gray-100 sm:py-2"
            />
            <button
                type="button"
                class="w-full rounded bg-gray-200 px-5 py-3 font-mono text-xs text-gray-900 transition-colors duration-200 hover:bg-gray-800 hover:text-white dark:bg-gray-900 dark:text-gray-200 sm:w-auto sm:py-3"
            >
                Subscribe
            </button>
        </div>

        <div class="flex flex-col items-center gap-2 pt-4 text-center">
            <span class="text-xs uppercase tracking-widest text-gray-600">Yours Truly,</span>
            <span class="font-serif text-2xl italic text-black dark:text-white sm:text-3xl">Kundan Nimba Goswami</span>
            <span class="text-xs uppercase tracking-widest text-gray-600">© 2026</span>
        </div>
    </div>
</footer>