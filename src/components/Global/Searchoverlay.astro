---
// src/components/Global/SearchOverlay.astro
import { Search, X } from "lucide-react";
import type { SearchItem } from "../../utils/searchIndex";

const { items = [] } = Astro.props as { items: SearchItem[] };
const serialized = JSON.stringify(items);
---

<div id="search-overlay-backdrop" class="fixed inset-0 z-[60] hidden bg-black/30 backdrop-blur-sm"></div>

<section id="search-overlay-dialog" class="fixed inset-x-0 top-24 z-[70] mx-auto hidden w-[44rem] max-w-[calc(100%-1.5rem)]">
  <div class="rounded-2xl border border-black/10 bg-white/90 p-4 shadow-xl backdrop-blur-md dark:border-white/10 dark:bg-zinc-900/90">
    <div class="flex items-center gap-2 rounded-xl border border-black/10 px-3 py-2 dark:border-white/10">
      <Search size={18} />
      <input
        id="search-overlay-input"
        type="text"
        placeholder="Search pages, blogs, labs, projects..."
        class="w-full bg-transparent outline-none"
      />
      <button id="search-overlay-close" type="button" class="rounded p-1 hover:bg-black/5 dark:hover:bg-white/10" aria-label="Close search">
        <X size={18} />
      </button>
    </div>

    <div id="search-overlay-results" class="mt-3 grid gap-2"></div>
  </div>
</section>

<script is:inline define:vars={{ serialized }}>
  const data = JSON.parse(serialized);

  const openBtn = document.getElementById("menu-search-open");
  const closeBtn = document.getElementById("search-overlay-close");
  const backdrop = document.getElementById("search-overlay-backdrop");
  const dialog = document.getElementById("search-overlay-dialog");
  const input = document.getElementById("search-overlay-input");
  const results = document.getElementById("search-overlay-results");

  function escapeHtml(value) {
    return value
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function openSearch() {
    backdrop?.classList.remove("hidden");
    dialog?.classList.remove("hidden");
    renderResults("");
    setTimeout(() => input?.focus(), 0);
  }

  function closeSearch() {
    backdrop?.classList.add("hidden");
    dialog?.classList.add("hidden");
    if (input) input.value = "";
    if (results) results.innerHTML = "";
  }

  function renderResults(query) {
    if (!results) return;

    const q = query.trim().toLowerCase();
    const filtered = data
      .filter((item) => {
        if (!q) return true;
        const hay = [item.title, item.kind, item.summary || "", ...(item.keywords || [])]
          .join(" ")
          .toLowerCase();
        return hay.includes(q);
      })
      .slice(0, 6);

    if (filtered.length === 0) {
      results.innerHTML =
        '<div class="rounded-xl border border-black/10 p-3 text-sm opacity-70 dark:border-white/10">No results found</div>';
      return;
    }

    results.innerHTML = filtered
      .map((item) => {
        const title = escapeHtml(item.title);
        const kind = escapeHtml(item.kind);
        const summary = item.summary ? `<div class="mt-1 text-xs opacity-70">${escapeHtml(item.summary)}</div>` : "";
        return `
          <a href="${item.href}" class="block rounded-xl border border-black/10 p-3 transition hover:bg-black/5 dark:border-white/10 dark:hover:bg-white/10">
            <div class="text-sm font-semibold">${title}</div>
            <div class="mt-1 text-xs opacity-70">${kind}</div>
            ${summary}
          </a>
        `;
      })
      .join("");
  }

  openBtn?.addEventListener("click", openSearch);
  closeBtn?.addEventListener("click", closeSearch);
  backdrop?.addEventListener("click", closeSearch);

  input?.addEventListener("input", (event) => {
    renderResults(event.target.value || "");
  });

  document.addEventListener("keydown", (event) => {
    const isOpen = dialog && !dialog.classList.contains("hidden");
    if (event.key === "Escape" && isOpen) {
      closeSearch();
    }
  });
</script>