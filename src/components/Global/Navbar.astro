---
import { Home, FlaskConical, BookOpenText, Code, Menu, FileUser, Search, X } from "lucide-react";
---

<nav class="font-sans sticky top-0 z-50 flex justify-center pt-4 md:pt-6">
  <div class="relative w-full max-w-full px-0 md:w-[48rem] md:max-w-[calc(100%-1.5rem)] md:px-0">
    <div
      class="group relative hidden items-center justify-between rounded-full border border-black/10 bg-white/70 px-8 py-3 shadow-[0_4px_20px_rgba(0,0,0,0.08)] backdrop-blur-md transition-all duration-300 dark:border-white/10 dark:bg-zinc-900/70 dark:shadow-[0_4px_20px_rgba(0,0,0,0.6)] md:flex"
    >
      <div class="pointer-events-none absolute inset-0 rounded-full bg-gradient-to-b from-white/60 to-transparent opacity-50 dark:from-white/10"></div>

      <div class="relative flex w-full justify-between text-sm font-medium">
        <a href="/" class="flex items-center gap-2 transition hover:text-black dark:hover:text-white">
          <Home client:load size={18} strokeWidth={2} />
          Home
        </a>

        <a href="/lab" class="flex items-center gap-2 transition hover:text-black dark:hover:text-white">
          <FlaskConical client:load size={18} strokeWidth={2} /> Lab
        </a>

        <a href="/blogs" class="flex items-center gap-2 transition hover:text-black dark:hover:text-white">
          <BookOpenText client:load size={18} strokeWidth={2} /> Blog
        </a>

        <a href="/projects" class="flex items-center gap-2 transition hover:text-black dark:hover:text-white">
          <Code client:load size={18} strokeWidth={2} /> Projects
        </a>

        <a href="/resume" class="flex items-center gap-2 transition hover:text-black dark:hover:text-white">
          <FileUser client:load size={18} strokeWidth={2} /> Resume
        </a>

        <button
          type="button"
          data-search-open
          class="flex items-center gap-2 transition hover:text-black dark:hover:text-white"
          aria-haspopup="dialog"
          aria-controls="search-overlay-dialog"
        >
          <Menu client:load size={18} strokeWidth={2} /> Menu
        </button>

        <button data-theme-toggle class="p-2" aria-label="Toggle theme">
          <span class="h-5 w-5 dark:hidden">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
            </svg>
          </span>
          <span class="hidden h-5 w-5 dark:block">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
            </svg>
          </span>
        </button>
      </div>
    </div>

    <div
      class="relative flex items-center justify-between rounded-full border border-black/10 bg-white/90 px-4 py-2 text-zinc-900 shadow-[0_14px_35px_rgba(0,0,0,0.14)] backdrop-blur-xl dark:border-white/10 dark:bg-zinc-950/95 dark:text-white dark:shadow-[0_14px_35px_rgba(0,0,0,0.35)] md:hidden"
    >
      <a href="/" class="rounded-full p-1.5 text-zinc-900 transition hover:text-zinc-700 dark:text-white dark:hover:text-white/90" aria-label="Home">
        <Home client:load size={18} strokeWidth={2} />
      </a>

      <div class="flex items-center gap-1">
        <button data-theme-toggle class="rounded-full p-1.5 text-zinc-700 transition hover:bg-black/5 hover:text-zinc-900 dark:text-white/90 dark:hover:bg-white/10 dark:hover:text-white" aria-label="Toggle theme">
          <span class="h-5 w-5 dark:hidden">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
            </svg>
          </span>
          <span class="hidden h-5 w-5 dark:block">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
            </svg>
          </span>
        </button>

        <button
          id="mobile-menu-toggle"
          type="button"
          class="rounded-full p-1.5 text-zinc-800 transition hover:bg-black/5 dark:text-white dark:hover:bg-white/10"
          aria-expanded="false"
          aria-controls="mobile-menu-panel"
          aria-label="Open menu"
        >
          <span id="mobile-menu-open-icon" class="block">
            <Menu client:load size={18} strokeWidth={2} />
          </span>
          <span id="mobile-menu-close-icon" class="hidden">
            <X size={18} strokeWidth={2} />
          </span>
        </button>
      </div>

      <div
        id="mobile-menu-panel"
        class="absolute right-3 top-[calc(100%+0.5rem)] hidden w-[min(17rem,calc(100vw-1.5rem))] rounded-3xl border border-black/10 bg-white/80 p-5 text-zinc-900 shadow-[0_20px_50px_rgba(0,0,0,0.16)] backdrop-blur-2xl dark:border-white/10 dark:bg-black/55 dark:text-white dark:shadow-[0_20px_50px_rgba(0,0,0,0.45)]"
      >
        <div class="flex items-center justify-between">
          <span class="text-[0.72rem] font-semibold uppercase tracking-[0.26em] text-zinc-500 dark:text-white/50">Menu</span>
          <button
            type="button"
            data-search-open
            class="rounded-full p-2 text-zinc-700 transition hover:bg-black/5 hover:text-zinc-900 dark:text-white/85 dark:hover:bg-white/10 dark:hover:text-white"
            aria-haspopup="dialog"
            aria-controls="search-overlay-dialog"
            aria-label="Search"
          >
            <Search size={19} strokeWidth={2} />
          </button>
        </div>

        <div class="mt-4 flex flex-col gap-1 text-sm font-medium text-zinc-700 dark:text-white/80">
          <a href="/lab" class="rounded-xl px-1 py-2 text-lg leading-none transition hover:text-zinc-900 dark:hover:text-white">Lab</a>
          <a href="/blogs" class="rounded-xl px-1 py-2 text-lg leading-none transition hover:text-zinc-900 dark:hover:text-white">Blog</a>
          <a href="/projects" class="rounded-xl px-1 py-2 text-lg leading-none transition hover:text-zinc-900 dark:hover:text-white">Projects</a>
          <a href="/resume" class="rounded-xl px-1 py-2 text-lg leading-none transition hover:text-zinc-900 dark:hover:text-white">Resume</a>
        </div>
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  const mobileToggle = document.getElementById('mobile-menu-toggle')
  const mobilePanel = document.getElementById('mobile-menu-panel')
  const mobileOpenIcon = document.getElementById('mobile-menu-open-icon')
  const mobileCloseIcon = document.getElementById('mobile-menu-close-icon')

  function setMobileMenuOpen(isOpen) {
    if (!mobileToggle || !mobilePanel || !mobileOpenIcon || !mobileCloseIcon) return
    mobilePanel.classList.toggle('hidden', !isOpen)
    mobileOpenIcon.classList.toggle('hidden', isOpen)
    mobileCloseIcon.classList.toggle('hidden', !isOpen)
    mobileToggle.setAttribute('aria-expanded', String(isOpen))
    mobileToggle.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu')
  }

  mobileToggle?.addEventListener('click', () => {
    if (!mobilePanel) return
    const isOpen = !mobilePanel.classList.contains('hidden')
    setMobileMenuOpen(!isOpen)
  })

  document.addEventListener('click', (event) => {
    if (!mobilePanel || !mobileToggle) return
    const target = event.target instanceof Element ? event.target : null
    const clickedInside = target && (mobilePanel.contains(target) || mobileToggle.contains(target))
    if (!clickedInside) setMobileMenuOpen(false)
  })

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      setMobileMenuOpen(false)
    }
  })
</script>