---
import { Home, FlaskConical, BookOpenText, Code, Menu, FileUser } from "lucide-react";
---

<nav class="font-sans fixed inset-x-0 top-0 z-50 flex justify-center pt-6">
  <div
    class="group relative flex items-center justify-between 
    w-[48rem] max-w-[calc(100%-1.5rem)]
    px-8 py-3 rounded-full

    backdrop-blur-md

    bg-white/70 dark:bg-zinc-900/70

    border border-black/10 dark:border-white/10

    shadow-[0_4px_20px_rgba(0,0,0,0.08)]
    dark:shadow-[0_4px_20px_rgba(0,0,0,0.6)]

    transition-all duration-300
  "
  >

    <!-- subtle top highlight -->
    <div class="pointer-events-none absolute inset-0 rounded-full
      bg-gradient-to-b
      from-white/60 to-transparent
      dark:from-white/10
      opacity-50">
    </div>

    <!-- nav items -->
    <div class="relative flex w-full justify-between text-sm font-medium">

      <a href="/" class="flex items-center gap-2 hover:text-black dark:hover:text-white transition">
        <Home client:load size={18} strokeWidth={2} />
        Home
      </a>

      <a href="/lab" class="flex items-center gap-2 hover:text-black dark:hover:text-white transition">
        <FlaskConical client:load size={18} strokeWidth={2} /> Lab
      </a>

      <a href="/blogs" class="flex items-center gap-2 hover:text-black dark:hover:text-white transition">
        <BookOpenText client:load size={18} strokeWidth={2} /> Blog
      </a>

      <a href="/projects" class="flex items-center gap-2 hover:text-black dark:hover:text-white transition">
        <Code client:load size={18} strokeWidth={2} /> Projects
      </a>

      <a href="/resume" class="flex items-center gap-2 hover:text-black dark:hover:text-white transition">
        <FileUser client:load size={18} strokeWidth={2} /> Resume
      </a>
      
      <button
        id="menu-search-open"
        type="button"
        class="flex items-center gap-2 hover:text-black dark:hover:text-white transition"
        aria-haspopup="dialog"
        aria-controls="search-overlay-dialog"
      >
        <Menu client:load size={18} strokeWidth={2} /> Menu
      </button>


      <button id="theme-toggle" class="p-2 ">
        <span class="w-5 h-5 dark:hidden">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
          </svg>
        </span>
        <span class="w-5 h-5 hidden dark:block">
        <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
        >
          <path d="M21 12.79A9 9 0 1111.21 3 
            7 7 0 0021 12.79z" />
        </svg>
        </span>
      </button>


    </div>
  </div>
</nav>