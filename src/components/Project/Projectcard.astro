---
import { SquareArrowOutUpRight } from 'lucide-react';
const { thumbnail, altText, title, hook, tags, category, date, projectUrl, githubUrl, link } = Astro.props;
---

<div class="mt-6 w-full">
  <article class="w-full overflow-hidden rounded-[10px] border border-gray-200 bg-white shadow-[0_20px_60px_rgba(0,0,0,0.1)] transition-transform duration-300 hover:-translate-y-1 dark:border-white/10 dark:bg-[#090909] dark:shadow-[0_20px_60px_rgba(0,0,0,0.35)]">
    <div class="flex flex-col">
      <div class="p-3.5 sm:p-4 md:p-4">
        <div class="mb-3 flex items-center justify-between">
          <span class="text-[9px] uppercase tracking-[0.18em] text-gray-600 dark:text-white/45">{category}</span>
          <div class="flex items-center gap-2">
            <span class="h-2 w-2 rounded-full bg-green-500 dark:bg-green-500"></span>
            <span class="text-[9px] uppercase tracking-[0.18em] text-gray-600 dark:text-white/45">{date}</span>
          </div>
        </div>

        <h2 class="mb-1.5 font-serif text-[clamp(1.05rem,1.8vw,1.45rem)] leading-[1] text-gray-900 dark:text-white">
          {title}
        </h2>

        <p class="max-w-xl text-[12px] leading-5 text-gray-600 sm:text-[13px] dark:text-white/60">
          {hook}
        </p>

        <div class="mt-3 flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <span class="rounded-full border border-gray-200 bg-gray-100 px-2 py-0.5 text-[8px] font-medium tracking-wide text-gray-700 backdrop-blur-sm dark:border-white/10 dark:bg-white/5 dark:text-white/70">
              {tag}
            </span>
          ))}
        </div>
      </div>

      <div class="border-t border-gray-200 bg-gray-50 p-2 sm:p-2.5 dark:border-black dark:bg-[#050505]">
        <a href={projectUrl} target="_blank" rel="noopener noreferrer" class="block overflow-hidden rounded-[5px] border border-gray-200 dark:border-white/10">
          <img
            src={thumbnail}
            alt={altText}
            class="aspect-[16/11] h-auto max-h-56 w-full object-cover transition-transform duration-500 hover:scale-[1.03]"
          />
        </a>
      </div>

      <div class="flex items-center justify-between gap-2.5 border-t border-gray-200 px-3.5 py-2 sm:px-4 sm:py-2.5 dark:border-white/8">
        <a
          href={link}
          target="_self"
          rel="noopener noreferrer"
          class="inline-flex h-8 items-center gap-1 rounded-full border border-gray-300 bg-gray-900 px-3 text-[10px] font-medium text-white transition duration-300 hover:bg-gray-800 dark:border-white/10 dark:bg-white dark:text-black dark:hover:bg-zinc-200"
        >
          Read More
          <span aria-hidden="true">→</span>
        </a>

        <div class="flex items-center gap-4 text-gray-600 dark:text-white/55">
          <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="transition hover:text-gray-900 dark:hover:text-white" aria-label="GitHub repository">
            <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
              <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.23c-3.34.73-4.04-1.41-4.04-1.41-.55-1.38-1.34-1.75-1.34-1.75-1.09-.75.08-.74.08-.74 1.21.08 1.85 1.22 1.85 1.22 1.07 1.82 2.8 1.29 3.48.98.11-.77.42-1.29.76-1.59-2.67-.3-5.47-1.32-5.47-5.87 0-1.3.47-2.37 1.24-3.21-.12-.3-.54-1.53.12-3.18 0 0 1.01-.32 3.3 1.22a11.6 11.6 0 0 1 6 0c2.29-1.54 3.3-1.22 3.3-1.22.66 1.65.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.21 0 4.56-2.81 5.56-5.49 5.86.43.37.81 1.1.81 2.22v3.29c0 .32.21.69.82.57A12 12 0 0 0 12 .5z"/>
            </svg>
          </a>

          <a href={projectUrl || '#'} class="transition hover:text-gray-900 dark:hover:text-white" aria-label="Open project">
            <SquareArrowOutUpRight client:load size={20} strokeWidth={2} />
          </a>
        </div>
      </div>
    </div>
  </article>
</div>

