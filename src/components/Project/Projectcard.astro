---
const { thumbnail, altText, title, hook, tags, category, date, projectUrl, githubUrl, link } = Astro.props;
import { SquareArrowOutUpRight } from 'lucide-react';
---

<div class="flex items-center justify-center w-full mt-8">
    <div class="flex flex-row bg-white dark:bg-black rounded p-6 w-full max-w-6xl border border-gray-200 dark:border-zinc-700 min-h-[250px] mx-auto">
      <!-- Left Side (70%) -->
      <div class="flex flex-col flex-[7] pr-6 justify-between h-full">
        <div>
          <div class="flex flex-row items-center gap-6 mb-2">
            <span class="text-xs uppercase text-gray-500 dark:text-gray-400">{category}</span>
            <span class="text-sm text-gray-500 dark:text-gray-400">{date}</span>
          </div>
          <h2 class="text-4xl font-serif text-2xl text-gray-900 dark:text-white mb-1">{title}</h2>
          <p class="text-gray-700 font-poppins text-sm dark:text-gray-300 mb-2">{hook}</p>
          <div class="flex flex-wrap mb-4">
            {tags.map((tag) => (
              <span class="mr-2 mb-2 px-3 py-1 bg-gray-100 dark:bg-zinc-800 text-xs font-mono rounded border border-gray-300 dark:border-zinc-700">
                {tag}
              </span>
            ))}
          </div>
        </div>
        <div class="mt-2 flex items-center gap-4">
          <a href={link} target="_self" rel="noopener noreferrer" class="text-sm font-mono text-black dark:text-white">Read More <span class="text-lg">→</span></a>
        </div>
        <div class="mt-8 flex items-center gap-2">
          <a href={githubUrl} target="_blank" class="mt-2 text-sm font-mono text-gray-500 dark:text-gray-400">
              <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
                <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.23c-3.34.73-4.04-1.41-4.04-1.41-.55-1.38-1.34-1.75-1.34-1.75-1.09-.75.08-.74.08-.74 1.21.08 1.85 1.22 1.85 1.22 1.07 1.82 2.8 1.29 3.48.98.11-.77.42-1.29.76-1.59-2.67-.3-5.47-1.32-5.47-5.87 0-1.3.47-2.37 1.24-3.21-.12-.3-.54-1.53.12-3.18 0 0 1.01-.32 3.3 1.22a11.6 11.6 0 0 1 6 0c2.29-1.54 3.3-1.22 3.3-1.22.66 1.65.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.21 0 4.56-2.81 5.56-5.49 5.86.43.37.81 1.1.81 2.22v3.29c0 .32.21.69.82.57A12 12 0 0 0 12 .5z"/>
              </svg>
          </a>
          <a href={projectUrl || '#'} class="mt-2 text-sm font-mono text-gray-500 dark:text-gray-400 ml-4"><SquareArrowOutUpRight client:load size={20} strokwidth={2} /></a>
        </div>
      </div>
      <!-- Right Side (30%) -->
      <div class="flex flex-col flex-[3] items-center justify-center h-full">
        <a href={projectUrl} target="_blank" rel="noopener noreferrer">
          <img src={thumbnail} alt={altText} class="w-80 h-60 rounded-md border border-gray-300 object-cover hover:scale-105 transition-transform "/>
        </a>
      </div>
    </div>
</div>

