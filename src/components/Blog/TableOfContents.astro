---
interface HeadingItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: HeadingItem[];
  mobile?: boolean;
}

const { headings = [], mobile = false } = Astro.props as Props;
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

{mobile ? (
    <details class="mx-auto w-full max-w-6xl px-6 md:hidden">
    <summary class="cursor-pointer rounded-xl border border-zinc-200 bg-white px-4 py-3 font-semibold text-zinc-900 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-100">
      Table of Contents
    </summary>

    <div class="mt-3 rounded-xl border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-950">
      <ul class="space-y-3 text-sm">
        {tocHeadings.map((item) => (
          <li class:list={[item.depth === 3 ? 'ml-4 text-zinc-500 dark:text-zinc-400' : '']}>
            <a href={`#${item.slug}`} class="hover:text-sky-700 dark:hover:text-sky-300">
              {item.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </details>
) : (
  <aside class="bg-zinc-50 p-6 dark:border-transparent dark:bg-black dark:shadow-none">
    <h2 class="mb-5 font-playfair text-3xl text-zinc-900 dark:text-zinc-100">Table of Contents</h2>

    {
      tocHeadings.length > 0 ? (
        <ul class="space-y-3 text-sm text-zinc-700 dark:text-zinc-300">
          {tocHeadings.map((item) => (
            <li class:list={[item.depth === 3 ? 'ml-4 text-zinc-500 dark:text-zinc-400' : '']}>
              <a class="transition-colors duration-200 hover:text-sky-700 dark:hover:text-sky-300" href={`#${item.slug}`}>
                {item.text}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-sm text-zinc-500 dark:text-zinc-500">No headings found in this article yet.</p>
      )
    }
  </aside>
)}