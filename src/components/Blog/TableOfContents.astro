---
interface HeadingItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: HeadingItem[];
}

const { headings = [] } = Astro.props as Props;
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

<aside class="bg-zinc-50 p-6 dark:border-transparent dark:bg-black dark:shadow-none">
  <h2 class="mb-5 font-playfair text-3xl text-zinc-900 dark:text-zinc-100">Table of Contents</h2>

  {
    tocHeadings.length > 0 ? (
      <ul class="space-y-3 text-sm text-zinc-700 dark:text-zinc-300">
        {tocHeadings.map((item) => (
          <li class:list={[item.depth === 3 ? 'ml-4 text-zinc-500 dark:text-zinc-400' : '']}>
            <a class="transition-colors duration-200 hover:text-sky-700 dark:hover:text-sky-300" href={`#${item.slug}`}>
              {item.text}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-sm text-zinc-500 dark:text-zinc-500">No headings found in this article yet.</p>
    )
  }
</aside>
