---
---
<section class="relative flex h-auto sm:h-96 w-full flex-col items-start justify-start py-8 sm:py-0">
    <div class="relative z-10 mx-auto flex w-full max-w-5xl flex-col items-start justify-start px-4 pt-6 sm:px-6 md:px-10 md:pt-24">
        <div class="flex gap-2 mb-6">
            <button class="filter-btn px-4 py-1 rounded-full bg-white text-black font-semibold text-xs shadow transition-all">ALL</button>
            <span class="text-gray-400 text-xs flex items-center"></span>
        </div>
        <h1 class="text-4xl sm:text-5xl md:text-7xl font-serif font-bold text-black mb-4 text-left dark:text-white">The Insights</h1>
        <p class="text-sm font-poppins md:text-xl text-gray-700 mb-8 text-left dark:text-white/70"></p>
        <div class="flex gap-3 mb-2">
            <button class="filter-btn px-4 py-1 rounded-full border border-gray-600 text-gray-600 font-semibold text-xs transition-all hover:bg-gray-800 hover:text-white dark:hover:bg-gray-800 dark:hover:text-white" data-category="TECH">TECH</button>
            <button class="filter-btn px-4 py-1 rounded-full border border-gray-600 text-gray-600 font-semibold text-xs transition-all hover:bg-gray-800 hover:text-white dark:hover:bg-gray-800 dark:hover:text-white" data-category="SOCIAL">SOCIAL</button>
        </div>
        <script type="module" client:load>
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const cat = btn.dataset.category;
                    window.dispatchEvent(new CustomEvent('blog-filter', { detail: cat }));
                });
            });
        </script>
    </div>
</section>