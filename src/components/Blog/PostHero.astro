---
interface Props {
  title: string;
  category: string;
  publishedDate: string;
  readingTimeMinutes: number;
}

const {
  title,
  category = 'TECH',
  publishedDate,
  readingTimeMinutes = 1,
} = Astro.props as Props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  weekday: 'short',
  day: 'numeric',
  month: 'short',
  year: 'numeric',
}).format(new Date(publishedDate));
---

<header class="relative z-10 mx-auto w-full max-w-6xl px-6 pb-10 pt-20 md:px-10 md:pt-20">
  <div class="max-w-4xl">
    <div class="mb-7 flex items-center gap-3">
      <span class="inline-flex border border-sky-600/35 bg-sky-100 px-3 py-1 text-[11px] font-bold tracking-[0.2em] text-sky-900 dark:border-sky-500/40 dark:bg-sky-500/15 dark:text-sky-300">
        {category}
      </span>
      <span class="text-xs uppercase tracking-[0.16em] text-zinc-600 dark:text-zinc-500">{readingTimeMinutes} min read</span>
    </div>

    <h1 class="max-w-5xl text-balance font-playfair text-4xl leading-tight text-zinc-900 dark:text-zinc-100 md:text-6xl">
      {title}
    </h1>

    <div class="mt-7">
      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-zinc-500 dark:text-zinc-500">Published</p>
      <p class="mt-1 text-xl font-semibold italic text-zinc-700 dark:text-zinc-300">{formattedDate}</p>
    </div>
  </div>
</header>
