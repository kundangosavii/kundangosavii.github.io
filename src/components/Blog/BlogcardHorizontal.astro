---
const { category, Time, Title, Description, link } = Astro.props;
---
<div class="w-full max-w-3xl bg-white bg-opacity-60 flex flex-row items-center gap-8 p-8 dark:bg-black ml-56">
    <div class="flex flex-col justify-between flex-1 gap-4">
        <div class="flex items-center gap-2 mb-2">
            <span class="h-2 w-2 rounded-full bg-yellow-400"></span>
            <span class="text-xs font-bold tracking-widest text-yellow-400 font-mono">{category || 'TECH'}</span>
            <span class="text-xs text-gray-600 ml-2">{Time || 'Mar 06'}</span>
        </div>
        <a href={link || '#'} class="block text-3xl font-serif text-black leading-tight dark:text-white">
            {Title || 'Blog Title Goes Here'}
        </a>
        <p class="text-gray-600 dark:text-gray-800 text-base">
            {Description || 'Short description of the blog post goes here. This should be concise and engaging.'}
        </p>
        <div class="mt-4">
            <a href={link || '#'} class="text-sm text-gray-600 tracking-widest font-mono flex items-center gap-2">
                READ MORE <span class="text-lg">→</span>
            </a>
        </div>
    </div>
</div>
